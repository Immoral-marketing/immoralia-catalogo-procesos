# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno requeridas — Catálogo de Procesos Immoralia (Next.js)
#
# Copia este fichero como .env para desarrollo local.
# En Vercel: Settings → Environment Variables → añade cada una por entorno.
#
# NEXT_PUBLIC_* → disponibles en cliente Y servidor
# Sin prefijo    → solo servidor (Route Handlers, Server Components, middleware)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# URL pública del proyecto Supabase (staging o prod según el entorno de Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co

# Clave anónima (pública) del proyecto Supabase
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Clave service_role (secreta) — solo para Route Handlers y Server Components
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Usada en /api/chat para el asistente IA
OPENAI_API_KEY=sk-proj-...

# ── Resend (email transaccional) ─────────────────────────────────────────────
# Usada en /api/leads/contact y /api/leads/onboarding
RESEND_API_KEY=re_...

# ── ClickUp ──────────────────────────────────────────────────────────────────
# Personal Token para crear tareas de lead
CLICKUP_TOKEN=pk_...

# ── Slack ────────────────────────────────────────────────────────────────────
# Bot Token con permisos chat:write
SLACK_BOT_TOKEN=xoxb-...

# ID del canal donde se notifican los leads (ej. C08F24QQFB2 — canal de producción)
SLACK_CHANNEL_ID=C...

# ID del canal alternativo usado en entornos no-producción de Vercel (preview/development).
# Si VERCEL_ENV !== 'production' y esta variable existe, se usa este canal en lugar
# de SLACK_CHANNEL_ID para evitar contaminar el canal del departamento con tests.
SLACK_CHANNEL_ID_STAGING=C...

# ── Dominio del site ─────────────────────────────────────────────────────────
# Usado en /api/partners/reset-password para validar el redirectTo
# Staging:    https://<tu-proyecto>.vercel.app
# Producción: https://procesos.immoralia.es
SITE_URL=https://procesos.immoralia.es

# ── GHL (booking widget) ─────────────────────────────────────────────────────
NEXT_PUBLIC_GHL_BOOKING_URL=https://api.leadconnectorhq.com/widget/booking/KMjgjNKzL0zYDoJyU8Ta

# ── Scripts de sincronización (NO necesarios en Vercel, solo local) ──────────
# Usadas por scripts/sync_processes_to_supabase.v2.mjs y manuales
STAGING_SUPABASE_URL=https://oxcjcsyowrlslbeylmih.supabase.co
STAGING_SUPABASE_SERVICE_ROLE_KEY=eyJ...
PROD_SUPABASE_URL=https://cvnuwrzpbvxtdxolwmxf.supabase.co
PROD_SUPABASE_SERVICE_ROLE_KEY=eyJ...
